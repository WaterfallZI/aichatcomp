# ── Cursor API ──────────────────────────────────────────────────────────
# Cursor cookie for AI access (required)
# How to get it:
#   1. Install Cursor editor: https://cursor.sh
#   2. Sign in to your Cursor account
#   3. Open DevTools in Cursor (Help > Toggle Developer Tools)
#   4. Go to Application > Cookies > cursor.sh
#   5. Copy the value of WorkosCursorSessionToken
#   OR use the Cursor-To-OpenAI tool: https://github.com/JiuZ-Chn/Cursor-To-OpenAI
#
# You can add multiple cookies separated by commas for load balancing:
# CURSOR_COOKIE=user_01abc...,user_01def...
CURSOR_COOKIE=your_cursor_cookie_here

# ── App Config ───────────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here
DATABASE_URL=sqlite:///aichat.db
OPERATOR_EMAIL=admin@yourdomain.com
ALLOWED_ORIGINS=*

# ── Nomchat Integration ──────────────────────────────────────────────────
NOMCHAT_URL=https://nomchat-id.up.railway.app

# ── Payment (optional) ───────────────────────────────────────────────────
AICHATPAY_URL=https://pay.aichat.ru
AICHATPAY_SECRET=your_payment_secret
